# pdm
.pdm.toml

# PEP 582
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# IDLE
*.pyc


# ═══════════════════════════════════════════════════════════
# TERRAFORM
# ═══════════════════════════════════════════════════════════

# Local .terraform directories (providers, modules cache)
**/.terraform/

# Terraform state files (.tfstate) — CONTIENEN SECRETOS
# NUNCA committear .tfstate files
*.tfstate
*.tfstate.*

# Terraform crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (sensitive variables)
# Los .tfvars pueden contener secrets (access keys, etc.)
*.tfvars
*.tfvars.json

# Override files (configuraciones locales de desarrollo)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files (binarios, contienen secrets)
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Provider lock file (opcional — recomendado mantenerlo en repo)
# Descomentar si NO quieres trackear el lock file:
# .terraform.lock.hcl


# ═══════════════════════════════════════════════════════════
# AWS / CLOUD
# ═══════════════════════════════════════════════════════════

# AWS CLI credentials/cache
.aws/
aws/

# SAM (Serverless Application Model)
.sam/
samconfig.toml

# CloudFormation outputs
*.output.json
*.output.yaml


